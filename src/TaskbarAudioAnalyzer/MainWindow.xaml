<Window
    x:Class="TaskbarAudioAnalyzer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Taskbar Audio Analyzer"
    Width="652"
    Height="48"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">
    <Border
        x:Name="Shell"
        Padding="8,4"
        Background="#45101317"
        BorderBrush="#22AEB7C2"
        BorderThickness="1"
        CornerRadius="8"
        MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Click="EnableStartupMenuItem_Click" Header="Enable startup" />
                <MenuItem Click="DisableStartupMenuItem_Click" Header="Disable startup" />
                <Separator />
                <MenuItem Click="ExitMenuItem_Click" Header="Exit" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="156" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Foreground="#AEB7C2" FontSize="10" Text="LUFS-S" ToolTip="EBU short-term loudness: 3-second window with ITU-R BS.1770 K-weighting" />
                <TextBlock x:Name="LoudnessText" Margin="5,0,0,0" Foreground="#F4F7FA" FontSize="18" FontWeight="SemiBold" Text="--.-" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Foreground="#AEB7C2" FontSize="11" Text="TP" ToolTip="4x interpolated peak estimate (dBFS)" />
                <TextBlock x:Name="TruePeakText" Margin="5,0,0,0" Foreground="#F4F7FA" FontSize="18" FontWeight="SemiBold" Text="--.-" />
            </StackPanel>

            <Grid
                Grid.Column="2"
                Height="38"
                Margin="0,0,28,0"
                ToolTip="Stereo phase correlation: +1 in phase, 0 uncorrelated, -1 out of phase">
                <Grid.RowDefinitions>
                    <RowDefinition Height="18" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="10" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#AEB7C2"
                        FontSize="10"
                        Text="PHASE" />
                    <TextBlock
                        x:Name="PhaseValueText"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="#F4F7FA"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="—" />
                </DockPanel>

                <Grid
                    x:Name="PhaseMeterTrack"
                    Grid.Row="1"
                    Height="7"
                    VerticalAlignment="Center"
                    ClipToBounds="False">
                    <Border CornerRadius="3.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#C8FF5B5B" />
                                <GradientStop Offset="0.5" Color="#B8FFD166" />
                                <GradientStop Offset="1" Color="#C86EE7F5" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        Width="1"
                        HorizontalAlignment="Center"
                        Background="#DDF4F7FA" />
                    <Canvas x:Name="PhaseMarkerCanvas" ClipToBounds="False">
                        <Rectangle
                            x:Name="PhaseMarker"
                            Canvas.Top="-1"
                            Width="3"
                            Height="9"
                            Fill="#FFFFFFFF"
                            RadiusX="1.5"
                            RadiusY="1.5"
                            Visibility="Collapsed" />
                    </Canvas>
                </Grid>

                <Grid Grid.Row="2" IsHitTestVisible="False">
                    <TextBlock HorizontalAlignment="Left" Foreground="#8FAEB7C2" FontSize="8" Text="−1" />
                    <TextBlock HorizontalAlignment="Center" Foreground="#8FAEB7C2" FontSize="8" Text="0" />
                    <TextBlock HorizontalAlignment="Right" Foreground="#8FAEB7C2" FontSize="8" Text="+1" />
                </Grid>
            </Grid>

            <Grid
                Grid.Column="3"
                Height="38"
                ClipToBounds="True"
                ToolTip="Log-frequency spectrum, approximately 60 Hz to 16 kHz">
                <Grid.RowDefinitions>
                    <RowDefinition Height="29" />
                    <RowDefinition Height="9" />
                </Grid.RowDefinitions>

                <Canvas
                    x:Name="SpectrumCanvas"
                    Height="29"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True" />

                <Border
                    Grid.Row="0"
                    Panel.ZIndex="2"
                    Margin="0,1,1,0"
                    Padding="3,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#B8101317"
                    CornerRadius="3"
                    IsHitTestVisible="False">
                    <TextBlock
                        x:Name="InputStatusText"
                        Foreground="#AEB7C2"
                        FontSize="8"
                        FontWeight="SemiBold"
                        Text="WIN" />
                </Border>

                <UniformGrid Grid.Row="0" Columns="5" IsHitTestVisible="False" Opacity="0.55">
                    <Border BorderBrush="#55AEB7C2" BorderThickness="0,0,1,0" Margin="0,22,0,0" />
                    <Border BorderBrush="#55AEB7C2" BorderThickness="0,0,1,0" Margin="0,22,0,0" />
                    <Border BorderBrush="#55AEB7C2" BorderThickness="0,0,1,0" Margin="0,22,0,0" />
                    <Border BorderBrush="#55AEB7C2" BorderThickness="0,0,1,0" Margin="0,22,0,0" />
                    <Border BorderBrush="#55AEB7C2" BorderThickness="0,0,1,0" Margin="0,22,0,0" />
                </UniformGrid>

                <UniformGrid Grid.Row="1" Columns="5" IsHitTestVisible="False">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#8FAEB7C2" FontSize="8" LineHeight="8" LineStackingStrategy="BlockLineHeight" Text="60" />
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#8FAEB7C2" FontSize="8" LineHeight="8" LineStackingStrategy="BlockLineHeight" Text="250" />
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#8FAEB7C2" FontSize="8" LineHeight="8" LineStackingStrategy="BlockLineHeight" Text="1k" />
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#8FAEB7C2" FontSize="8" LineHeight="8" LineStackingStrategy="BlockLineHeight" Text="4k" />
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#8FAEB7C2" FontSize="8" LineHeight="8" LineStackingStrategy="BlockLineHeight" Text="16k" />
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</Window>
